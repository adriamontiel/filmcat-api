plan_alacartamovimentinternet":0,"plan_valscampanya":"S"}]},{"peli_pelicula":4397,"peli_titol":"(VOSE) EL ARQUITECTO","peli_videoextern":"https://www.youtube.com/watch?v=KKJbTW7-Ee4&t=2s","peli_durada":"107","peli_esdeveniment":"N","peli_posterqualitat":"","peli_classificacio":"12 Anys","peli_generacomercial":"DRAMA","Pelicules2":{"pel2_pelicula":4397,"pel2_grup":"N","pel2_sinopsis":"1983. El nou govern francès convoca el concurs darquitectura més gran. Cobejat pels grans estudis, el guanyador és, sorprenentment, un absolut desconegut: Johan Otto von Spreckelsen, un professor darquitectura danès que fins aleshores només havia construït casa seva i tres petites capelles. De sobte, es troba al capdavant dun projecte colossal: la construcció de lArc de la Defensa de París. Spreck no trigarà a descobrir que, per preservar la seva visió, haurà denfrontar-se al joc polític. Comença aleshores el veritable pols entre lart i el poder."},"Planificacions":[{"plan_planificacio":193873,"plan_data":"2026-03-26","plan_sala":"008","plan_sessio":5,"plan_pelicula":4397,"plan_tipuspreu":1,"plan_fila":"17","plan_columna":"15","plan_horainici":"20:30:00","plan_horafi":"22:17:00","plan_numerada":"N","plan_ocupacio":"0","plan_internetbloqueig":"N","plan_fidelitzacioactiva":"S","plan_aforament":"                               LLLLL  LLLLLL LLLLLL  LLLLLLLLLLLLL  LLLLLLLLLLLLL  LLLLLLL LLLLL  LLLLLLL        LLLLLLL  LLLL  LLLLLLL  LLLL  LLLLLLL  LLLL  LLLLLLL  LLLL  LLLLLLL  LLLL  LLLLLLLLLLLLL  LLLLLLLLLLLLL  LLLLLLLLLLLLLLLLLLLLLL               ","plan_observacions":null,"plan_ultimamodificacio":"2026-03-18T18:25:22.000Z","plan_article":"","plan_imprimiraforament":"N","plan_dataeliminacio":null,"plan_operarieliminacio":null,"plan_esdeveniment":"N","plan_minutsentradasala":15,"plan_atmbloqueig":"N","plan_taquilllabloqueig":"N","plan_horavall":"S","plan_entradesgratis":"S","plan_estat":"O","plan_aplicarsuplementvip":"S","plan_alacartamovimentinternet":0,"plan_valscampanya":"S"}]},{"