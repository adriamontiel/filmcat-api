a en néixer, durà a terme un pla ambiciós: eliminar els set familiars que s'interposen en el seu camí, incloent-hi el seu propi avi (Ed Harris). Tot i això, també haurà de lidiar amb la complicada relació amb la Julia (Margaret Qualley), el seu primer amor."},"Planificacions":[{"plan_planificacio":195369,"plan_data":"2026-05-28","plan_sala":"008","plan_sessio":5,"plan_pelicula":4454,"plan_tipuspreu":1,"plan_fila":"17","plan_columna":"15","plan_horainici":"19:30:00","plan_horafi":"21:15:00","plan_numerada":"N","plan_ocupacio":"0","plan_internetbloqueig":"N","plan_fidelitzacioactiva":"S","plan_aforament":"                               LLLLL  LLLLLL LLLLLL  LLLLLLLLLLLLL  LLLLLLLLLLLLL  LLLLLLL LLLLL  LLLLLLL        LLLLLLL  LLLL  LLLLLLL  LLLL  LLLLLLL  LLLL  LLLLLLL  LLLL  LLLLLLL  LLLL  LLLLLLLLLLLLL  LLLLLLLLLLLLL  LLLLLLLLLLLLLLLLLLLLLL               ","plan_observacions":null,"plan_ultimamodificacio":"2026-05-20T21:44:53.000Z","plan_article":"","plan_imprimiraforament":"N","plan_dataeliminacio":null,"plan_operarieliminacio":null,"plan_esdeveniment":"N","plan_minutsentradasala":15,"plan_atmbloqueig":"N","plan_taquilllabloqueig":"N","plan_horavall":"S","plan_entradesgratis":"S","plan_estat":"O","plan_aplicarsuplementvip":"S","plan_alacartamovimentinternet":0,"plan_valscampanya":"S"},{"plan_planificacio":195370,"plan_data":"2026-05-28","plan_sala":"008","plan_sessio":6,"plan_pelicula":4454,"plan_tipuspreu":1,"plan_fila":"0","plan_columna":"0","plan_horainici":"21:45:00","plan_horafi":"23:30:00","plan_numerada":"N","plan_ocupacio":"0","plan_internetbloqueig":"N","plan_fidelitzacioactiva":"S","plan_aforament":null,"plan_observacions":null,"plan_ultimamodificacio":"2026-05-20T21:45:07.000Z","plan_article":"","plan_imprimiraforament":"N","plan_dataeliminacio":null,"plan_operarieliminacio":null,"plan_esdeveniment":"N","plan_minutsentradasala":15,"plan_atmbloqueig":"N","plan_taquilllabloqueig":"N","plan_horavall":"S","plan_entradesgratis":"S","plan_estat":"O","plan_aplic