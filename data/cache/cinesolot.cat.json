den senyors de la guerra imperials escampats per tota la galàxia. Mentrestant, la incipient Nova República s'esforça per protegir tot allò per la qual cosa va lluitar la Rebel·lió, obtenint l'ajuda del llegendari caçarecompenses mandalorià Din Djarin (Pedro Pascal) i el seu jove aprenent Grogu. Dirigida per Jon Favreau, Star Wars: The Mandalorian and Grogu també està protagonitzada per Sigourney Weaver i produïda per Jon Favreau, Kathleen Kennedy, Dave Filoni i Ian Bryce, amb música composta per Ludwig Göransson."},"Planificacions":[{"plan_planificacio":195513,"plan_data":"2026-06-03","plan_sala":"005","plan_sessio":4,"plan_pelicula":4448,"plan_tipuspreu":8,"plan_fila":"19","plan_columna":"20","plan_horainici":"18:00:00","plan_horafi":"20:11:00","plan_numerada":"N","plan_ocupacio":"0","plan_internetbloqueig":"N","plan_fidelitzacioactiva":"S","plan_aforament":"                                           LLLLLL  LLLLLL    LLLLLLLL  LLLLLLLL LLLLLLLLL  LLLLLLLLLLLLLLLLLL  LLLLLLLLL LLLLLLLL  LLLLLLLLL           LLLLLLLLL  LLLLLLL  LLLLLLLLL  LLLLLLL  LLLLLLLLL  LLLLLLL  LLLLLLLLL  LLLLLLL  LLLLLLLLL  LLLLLLL  LLLLLLLLLLLLLLLLLL  LLLLLLLLLLLLLLLLLL  LLLLLLLLLLLLLLLLLL  LLLLLLLLLLLLLLLLLL  LLLLLLLLLLLLLLLLLLLLLLLLLLLLL                    ","plan_observacions":null,"plan_ultimamodificacio":null,"plan_article":"","plan_imprimiraforament":"N","plan_dataeliminacio":null,"plan_operarieliminacio":null,"plan_esdeveniment":"N","plan_minutsentradasala":15,"plan_atmbloqueig":"N","plan_taquilllabloqueig":"N","plan_horavall":"S","plan_entradesgratis":"S","plan_estat":"O","plan_aplicarsuplementvip":"S","plan_alacartamovimentinternet":0,"plan_valscampanya":"S"},{"plan_planificacio":195514,"plan_data":"2026-06-03","plan_sala":"005","plan_sessio":8,"plan_pelicula":4448,"plan_tipuspreu":8,"plan_fila":"19","plan_columna":"20","plan_horainici":"21:00:00","plan_horafi":"23:11:00","plan_numerada":"N","plan_ocupacio":"0","plan_internetbloqueig":"N","plan_fidelitzacioactiva":"S","plan_aforamen